# Copie este arquivo para .env.local e preencha com seus valores do Supabase
# Nunca comite o .env.local no Git

# Encontre em: Supabase Dashboard → Project Settings → API
VITE_SUPABASE_URL=https://SEU_PROJECT_ID.supabase.co
VITE_SUPABASE_ANON_KEY=sua_anon_key_aqui

# Usado apenas nas Edge Functions (secret — nunca expor no frontend)
# Configurar em: Supabase Dashboard → Edge Functions → Secrets
# SUPABASE_SERVICE_ROLE_KEY=sua_service_role_key_aqui
# SITE_URL=https://seu-site.vercel.app
